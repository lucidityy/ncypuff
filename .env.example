# --- Admin Panel (/admin) — required for login + /api/admin/* routes ---
# ADMIN_USERNAME=Admin
# ADMIN_PASSWORD=
# ADMIN_SESSION_SECRET=          (min 16 chars)

# --- Upstash Redis (data persistence in production) ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Vercel Blob (image upload) ---
# BLOB_READ_WRITE_TOKEN=

# --- Contact links (public — used client-side) ---
# NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/33XXXXXXXXX
# NEXT_PUBLIC_SIGNAL_URL=https://signal.me/#p/+33XXXXXXXXX
# NEXT_PUBLIC_SNAPCHAT_URL=https://www.snapchat.com/add/YOUR_USERNAME

# --- Delivery label (optional override) ---
# NEXT_PUBLIC_DELIVERY_LABEL=Livraison offerte dès 30 €
